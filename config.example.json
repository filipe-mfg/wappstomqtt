{
  "_comment": "ThingsBoard ↔ Wappsto bridge – example configuration",

  "log_level": "info",

  "thingsboard": {
    "_comment": "This is the MQTT broker where the ThingsBoard gateway publishes. Typically this is a Mosquitto instance that the bridge and the gateway both connect to — there is no real ThingsBoard running.",
    "host": "localhost",
    "port": 1884,
    "username": "",
    "password": "",
    "client_id": "tb-wappsto-bridge",
    "keepalive_sec": 60,

    "_comment_topics": "Subscribing to the full gateway + gateway-device protocol so the bridge can emulate the ThingsBoard server. Leave defaults unless you know what you're doing.",
    "subscribe_topics": [
      "v1/devices/me/rpc/request/+",
      "v1/devices/me/attributes/request/+",
      "v1/devices/me/attributes",
      "v1/devices/me/telemetry",
      "v1/gateway/telemetry",
      "v1/gateway/attributes",
      "v1/gateway/attributes/request/+",
      "v1/gateway/connect",
      "v1/gateway/disconnect",
      "v1/gateway/rpc"
    ],

    "tls": {
      "enabled": false,
      "ca_cert": "",
      "client_cert": "",
      "client_key": ""
    },

    "_comment_api": "REST API credentials for Wappsto→ThingsBoard RPC (control direction). The Gateway MQTT API does not support external RPC triggering, so we use the HTTP API instead.",
    "api": {
      "enabled": false,
      "host": "",
      "_comment_host": "Leave empty to use same host as MQTT. Override if API is on a different host/port.",
      "port": 8080,
      "tls": false,
      "username": "admin@example.com",
      "password": "admin_password",
      "timeout_sec": 10
    }
  },

  "wappsto": {
    "_comment_host": "collector.wappsto.com is the JSON-RPC IoT endpoint. wappsto.com is just the web UI (HTTPS) and will return HTTP 400 for our protocol.",
    "host": "collector.wappsto.com",
    "port": 443,
    "_comment_certs": "Download certificates from IoT Certificate Manager on wappsto.com",
    "ca_cert":     "certs/ca.crt",
    "client_cert": "certs/client.crt",
    "client_key":  "certs/client.key",
    "_comment_uuid": "Set to 'auto' to read network UUID from client certificate CN",
    "network_uuid": "auto",
    "rpc_timeout_sec": 5,
    "ping_interval_sec": 30
  },

  "gateway_config": {
    "_comment": "Serves configuration to the ThingsBoard IoT Gateway from Wappsto. Each entry becomes a rw value in the 'Gateway Config' device. Edit the control state in the Wappsto UI — the gateway reloads automatically.",
    "enabled": true,
    "wappsto_device_name": "Gateway Config",

    "session_limits": {
      "maxPayloadSize": 65536,
      "maxInflightMessages": 100
    },

    "entries": [
      {
        "tb_key": "general_configuration",
        "wappsto_value_name": "general_configuration",
        "shared": false,
        "default_json": {
          "host": "localhost",
          "port": 1884,
          "remoteConfiguration": true,
          "statistics": { "enable": true, "statsSendPeriodInSeconds": 60 },
          "security": { "type": "accessToken", "accessToken": "REPLACE_ME" },
          "qos": 1,
          "reportStrategy": { "type": "ON_RECEIVED" }
        }
      },
      {
        "tb_key": "active_connectors",
        "wappsto_value_name": "active_connectors",
        "shared": false,
        "default_json": ["OPCUA"]
      },
      {
        "tb_key": "storage_configuration",
        "wappsto_value_name": "storage_configuration",
        "shared": false,
        "default_json": {
          "type": "memory",
          "read_records_count": 100,
          "max_records_count": 100000
        }
      },
      {
        "tb_key": "OPCUA",
        "wappsto_value_name": "OPCUA",
        "shared": true,
        "default_json": {
          "name": "OPCUA",
          "type": "opcua",
          "configurationJson": {
            "server": {
              "url": "opc.tcp://10.8.0.2:53530/OPCUA/SimulationServer",
              "timeoutInMillis": 5000,
              "scanPeriodInMillis": 5000,
              "pollPeriodInMillis": 5000,
              "enableSubscriptions": true,
              "subCheckPeriodInMillis": 100,
              "security": "Basic128Rsa15",
              "identity": { "type": "anonymous" }
            },
            "mapping": []
          }
        }
      }
    ]
  },

  "mapping": {
    "_comment_mode": "Use 'dynamic' to auto-discover devices, 'static' for explicit mapping",
    "mode": "dynamic",

    "_comment_dynamic": "Dynamic mode options",
    "auto_create_values": true,
    "default_min":  -1e9,
    "default_max":   1e9,
    "default_step":  1.0,
    "default_permission": "r",

    "_comment_static": "Static device/value mappings (used in static mode, or to override specific devices in dynamic mode)",
    "devices": [
      {
        "tb_device":           "TemperatureSensor01",
        "wappsto_device_name": "Temperature Sensor 01",
        "wappsto_device_uuid": "",
        "values": [
          {
            "tb_key":             "temperature",
            "wappsto_value_name": "Temperature",
            "wappsto_value_uuid": "",
            "type":       "number",
            "min":        -50,
            "max":        150,
            "step":       0.1,
            "unit":       "°C",
            "permission": "r"
          },
          {
            "tb_key":             "humidity",
            "wappsto_value_name": "Humidity",
            "wappsto_value_uuid": "",
            "type":   "number",
            "min":    0,
            "max":    100,
            "step":   1,
            "unit":   "%",
            "permission": "r"
          }
        ]
      },
      {
        "tb_device":           "SmartActuator01",
        "wappsto_device_name": "Smart Actuator 01",
        "wappsto_device_uuid": "",
        "values": [
          {
            "tb_key":             "status",
            "wappsto_value_name": "Status",
            "type":       "number",
            "min":        0,
            "max":        1,
            "step":       1,
            "unit":       "",
            "permission": "r"
          },
          {
            "tb_key":             "setpoint",
            "wappsto_value_name": "Setpoint",
            "type":       "number",
            "min":        0,
            "max":        100,
            "step":       1,
            "unit":       "%",
            "permission": "rw",
            "_comment":   "When Wappsto control changes, call this RPC on the TB device",
            "rpc_method": "setSetpoint",
            "rpc_params_template": "{\"value\": {{value}}}"
          }
        ]
      }
    ]
  }
}
